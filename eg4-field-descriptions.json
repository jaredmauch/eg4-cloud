  "field_patterns": [
    {
      "pattern": "^FUNC_LSP_BAT_FIRST_(\\d+)_EN$",
      "family": "PV Charge Priority",
      "description": "LSP slot {slot} ({time}) — PV Charge Priority / Charge Priority"
    },
    {
      "pattern": "^FUNC_LSP_BYPASS_(\\d+)_EN$",
      "family": "Bypass Mode",
      "description": "LSP slot {slot} ({time}) — Bypass Mode"
    },
    {
      "pattern": "^FUNC_LSP_OUTPUT_(\\d+)_EN$",
      "family": "Output priority",
      "description": "LSP slot {slot} ({time}) — Output priority"
    }
  ],
